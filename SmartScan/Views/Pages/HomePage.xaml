<Page x:Class="SmartScan.Views.Pages.HomePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="HomePage">

    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <ui:TextBlock FontTypography="Title" Text="SmartScan Home" HorizontalAlignment="Center"/>
            
            <ui:CardControl Icon="{ui:SymbolIcon Scanner24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Select Scanner" />
                        <ui:TextBlock FontTypography="Caption" Text="WIA, TWAIN, and eSCL are supported." Appearance="Secondary" />
                    </StackPanel>
                </ui:CardControl.Header>
                
                <ComboBox Width="250" 
                          ItemsSource="{Binding Scanners}" 
                          SelectedItem="{Binding SelectedScanner}" />
            </ui:CardControl>

            <ui:Button Appearance="Primary" 
                       Command="{Binding LoadScannersCommand}" 
                       Content="Detect Scanners" 
                       Icon="{ui:SymbolIcon ArrowClockwise24}" 
                       HorizontalAlignment="Center" />

            <ui:ProgressRing IsIndeterminate="{Binding IsLoading}" 
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" 
                             HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Page>
