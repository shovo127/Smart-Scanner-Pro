<Page x:Class="SmartScan.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SettingsPage">

    <Grid>
        <StackPanel Margin="20">
            <ui:TextBlock FontTypography="Title" Text="Settings" />
            
            <ui:CardControl Icon="{ui:SymbolIcon WeatherMoon24}">
                <ui:CardControl.Header>
                    <StackPanel>
                        <ui:TextBlock FontTypography="BodyStrong" Text="Dark Mode" />
                        <ui:TextBlock FontTypography="Caption" Text="Toggle application theme" Appearance="Secondary" />
                    </StackPanel>
                </ui:CardControl.Header>
                
                <ui:ToggleSwitch IsChecked="{Binding IsDarkMode}" />
            </ui:CardControl>
        </StackPanel>
    </Grid>
</Page>
