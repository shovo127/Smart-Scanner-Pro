<Window x:Class="SmartScannerPro.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:helpers="clr-namespace:SmartScannerPro.UI.Helpers"
        xmlns:viewmodels="clr-namespace:SmartScannerPro.UI.ViewModels"
        mc:Ignorable="d"
        Title="Smart Scanner Pro" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        d:DataContext="{d:DesignInstance Type=viewmodels:WorkspaceViewModel}"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityConverter" Invert="False" />
        <helpers:NullToVisibilityConverter x:Key="NullToVisibilityCollapsedConverter" Invert="True" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Main Workspace -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="200" />
            </Grid.ColumnDefinitions>

            <!-- Left Sidebar: Scanners & Settings -->
            <Border Grid.Column="0" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Background="{DynamicResource CardBackgroundBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="16">
                        <!-- Header -->
                        <TextBlock Text="Smart Scanner Pro" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>

                        <!-- Scanners Card -->
                        <ui:Card Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Available Scanners" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox Grid.Column="0" ItemsSource="{Binding Scanners}" SelectedItem="{Binding SelectedScanner}" DisplayMemberPath="Name" VerticalAlignment="Center" Margin="0,0,8,0" />
                                    <ui:Button Grid.Column="1" Command="{Binding RefreshScannersCommand}" Icon="{ui:SymbolIcon Refresh24}" Content="" Appearance="Secondary" ToolTip="Refresh Scanner List" />
                                </Grid>

                                <!-- Scanner details card -->
                                <ui:Card Background="{DynamicResource ControlAltFillColorQuaternaryBrush}" Padding="8" Margin="0,8,0,0" Visibility="{Binding SelectedScanner, Converter={StaticResource NullToVisibilityConverter}}">
                                    <StackPanel>
                                        <TextBlock Text="{Binding SelectedScanner.Manufacturer, StringFormat='Mfg: {0}'}" FontSize="11" Opacity="0.8" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding SelectedScanner.ConnectionType, StringFormat='Connection: {0}'}" FontSize="11" Opacity="0.8" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding SelectedScanner.Driver.Name, StringFormat='Driver: {0}'}" FontSize="11" Opacity="0.8" Margin="0,0,0,6" />
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="Status: Ready" FontSize="11" FontWeight="SemiBold" Foreground="Green" Margin="0,0,4,0" />
                                            <TextBlock Text="•" Opacity="0.5" Margin="0,0,4,0" />
                                            <TextBlock Text="Health: Good" FontSize="11" FontWeight="SemiBold" Foreground="Green" />
                                        </StackPanel>
                                    </StackPanel>
                                </ui:Card>
                            </StackPanel>
                        </ui:Card>

                        <!-- Settings Card -->
                        <ui:Card Padding="12" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Scan Settings" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12" />

                                <!-- Paper Source -->
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Source" FontSize="12" Opacity="0.8" Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding Sources}" SelectedItem="{Binding SelectedSource}" />
                                </StackPanel>

                                <!-- Color Mode -->
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Color Mode" FontSize="12" Opacity="0.8" Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding ColorModes}" SelectedItem="{Binding SelectedColorMode}" />
                                </StackPanel>

                                <!-- Resolution -->
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="Resolution (DPI)" FontSize="12" Opacity="0.8" Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding Resolutions}" SelectedItem="{Binding SelectedResolution}" />
                                </StackPanel>

                                <!-- Paper Size -->
                                <StackPanel Margin="0,0,0,12">
                                    <TextBlock Text="Paper Size" FontSize="12" Opacity="0.8" Margin="0,0,0,4" />
                                    <ComboBox ItemsSource="{Binding PaperSizes}" SelectedItem="{Binding SelectedPaperSize}" />
                                </StackPanel>

                                <Separator Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="0,4,0,12" />

                                <!-- File Name Pattern -->
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="File Name Pattern" FontSize="12" Opacity="0.8" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding FileNamePattern, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>

                                <!-- Output Folder -->
                                <StackPanel Margin="0,0,0,4">
                                    <TextBlock Text="Output Folder" FontSize="12" Opacity="0.8" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding OutputFolder, UpdateSourceTrigger=PropertyChanged}" />
                                </StackPanel>
                            </StackPanel>
                        </ui:Card>

                        <!-- Scan Trigger -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ui:Button Grid.Column="0" Command="{Binding StartScanCommand}" Content="Scan Now" Icon="{ui:SymbolIcon DocumentScan24}" Appearance="Primary" Height="40" HorizontalAlignment="Stretch" Margin="0,0,8,0" />
                            <ui:Button Grid.Column="1" Command="{Binding CancelScanCommand}" Content="Cancel" Appearance="Secondary" Height="40" Visibility="{Binding IsScanning, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Center Panel: Preview Area -->
            <Grid Grid.Column="1" Background="{DynamicResource SolidBackgroundFillColorBaseBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Zoomable Image Canvas -->
                <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Background="#111111">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image Source="{Binding SelectedPage.PreviewImage}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" Margin="24">
                            <Image.LayoutTransform>
                                <TransformGroup>
                                    <RotateTransform Angle="{Binding SelectedPage.Rotation}" />
                                    <ScaleTransform ScaleX="{Binding ZoomLevel}" ScaleY="{Binding ZoomLevel}" />
                                </TransformGroup>
                            </Image.LayoutTransform>
                        </Image>

                        <!-- Placeholder when no page is selected -->
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding SelectedPage, Converter={StaticResource NullToVisibilityCollapsedConverter}}">
                            <ui:SymbolIcon Symbol="DocumentScan24" Filled="True" FontSize="48" Foreground="{DynamicResource AccentTextFillColorDisabledBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                            <TextBlock Text="No page selected for preview." FontSize="14" Opacity="0.6" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="Select a scanner and click 'Scan Now' to acquire pages." FontSize="12" Opacity="0.4" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>

                <!-- Floating/Preview Toolbar -->
                <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="12">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Page operations -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                            <ui:Button Command="{Binding RotatePageCommand}" Icon="{ui:SymbolIcon RotateRight24}" Content="Rotate" ToolTip="Rotate 90° Right" Margin="0,0,8,0" />
                            <ui:Button Command="{Binding RescanPageCommand}" Icon="{ui:SymbolIcon ArrowReset24}" Content="Rescan" ToolTip="Rescan this page" Margin="0,0,8,0" />
                            <ui:Button Command="{Binding DeletePageCommand}" Icon="{ui:SymbolIcon Delete24}" Content="Delete" Appearance="Danger" ToolTip="Delete this page" />
                        </StackPanel>

                        <!-- Zoom Controls -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <ui:Button Command="{Binding ZoomOutCommand}" Icon="{ui:SymbolIcon ZoomOut24}" Content="" ToolTip="Zoom Out" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding ZoomLevel, StringFormat={}{0:P0}}" VerticalAlignment="Center" Margin="4,0" FontSize="12" Width="44" TextAlignment="Center" />
                            <ui:Button Command="{Binding ZoomInCommand}" Icon="{ui:SymbolIcon ZoomIn24}" Content="" ToolTip="Zoom In" Margin="8,0" />
                            <Separator Background="{DynamicResource DividerStrokeColorDefaultBrush}" Margin="8,0" Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" />
                            <ui:Button Command="{Binding ZoomFitWidthCommand}" Content="Fit Width" Margin="8,0" />
                            <ui:Button Command="{Binding ZoomFitPageCommand}" Content="Fit Page" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right Sidebar: Scan Queue -->
            <Border Grid.Column="2" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1,0,0,0" Background="{DynamicResource CardBackgroundBrush}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Scan Queue" FontSize="14" FontWeight="SemiBold" Margin="12,12,12,8" />

                    <!-- Thumbnail List with Drag-and-Drop enabled -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding Pages}" SelectedItem="{Binding SelectedPage}" helpers:DragDropHelper.IsDragSource="True" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <ui:Card Margin="0,4" Padding="6" Background="{DynamicResource ControlAltFillColorTertiaryBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <!-- Thumbnail -->
                                        <Border Grid.Row="0" BorderBrush="{DynamicResource DividerStrokeColorDefaultBrush}" BorderThickness="1" Width="140" Height="100" CornerRadius="4" ClipToBounds="True" Background="#222222">
                                            <Image Source="{Binding Thumbnail}" Stretch="Uniform" RenderOptions.BitmapScalingMode="LowQuality">
                                                <Image.LayoutTransform>
                                                    <RotateTransform Angle="{Binding Rotation}" />
                                                </Image.LayoutTransform>
                                            </Image>
                                        </Border>
                                        <!-- Page Label -->
                                        <TextBlock Grid.Row="1" Text="{Binding PageNumber, StringFormat='Page {0}'}" FontSize="12" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,4,0,0" />
                                    </Grid>
                                </ui:Card>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="1" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="8,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status indicator -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Status:" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12" VerticalAlignment="Center" Foreground="{DynamicResource AccentTextFillColorPrimaryBrush}"/>
                </StackPanel>

                <!-- Operation description and progress bar -->
                <Grid Grid.Column="1" Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding ProgressMessage}" FontSize="11" Opacity="0.7" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                    <ProgressBar Grid.Column="1" Value="{Binding ProgressPercentage}" Height="12" VerticalAlignment="Center" Visibility="{Binding ShowProgressBar, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </Grid>

                <TextBlock Grid.Column="2" Text="Smart Scanner Pro v1.0.0" FontSize="11" Opacity="0.5" VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>
